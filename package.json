{
  "name": "crypto-realtime-monitoring",
  "version": "2.0.0",
  "description": "Real-time crypto market monitoring system with stream processing",
  "main": "dist/processor.js",
  "author": "Cheryle Awa Efreni",
  "license": "MIT",
  "engines": {
    "node": ">=16.0.0"
  },
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist",
    "dev:processor": "ts-node processor.ts",
    "dev:server": "ts-node websocket-server.ts",
    "start": "node dist/processor.js",
    "server": "node dist/websocket-server.js",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "kafkajs": "^2.2.4",
    "mongodb": "^6.0.0",
    "ws": "^8.14.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.0.0",
    "@types/ws": "^8.18.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.1.6"
  }
}
